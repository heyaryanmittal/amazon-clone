# =============================================
# ROOT .gitignore — Amazon Clone
# =============================================

# ---- OS Files ----
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ---- Editor / IDE ----
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.swp
*.swo
.editorconfig

# ---- Logs ----
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ---- Node (both frontend & backend) ----
node_modules/
jspm_packages/

# ---- Environment Variables (NEVER commit secrets) ----
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.production

# ---- Backend specific ----
backend/uploads/
backend/*.log

# ---- Frontend Build Output ----
frontend/dist/
frontend/dist-ssr/
frontend/.vite/
frontend/coverage/

# ---- Misc ----
*.tgz
*.zip
.cache/
.parcelcache/
